# Marque la racine du projet pour Lombok (stoppe la remontée de config).
config.stopBubbling = true

# Ajoute @lombok.Generated sur le code généré (getters/setters/builders/
# constructeurs, etc.). JaCoCo exclut automatiquement les éléments annotés
# @Generated du calcul de couverture : seul le code écrit à la main est mesuré.
lombok.addLombokGeneratedAnnotation = true
